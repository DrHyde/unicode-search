{
  "name": "unicode-search",
  "productName": "Unicode Search",
  "version": "1.0.0",
  "description": "Search for Unicode characters, by name, by code point, and by encoded bytes",
  "main": "main.js",
  "bin": {
    "unicode-search": "./src/cli/run-cli.js"
  },
  "scripts": {
    "ensure:unicode-data": "node scripts/ensure-unicode-data.js",
    "build:icon": "node scripts/build-icon.js",
    "build:cli": "npm run ensure:unicode-data && node scripts/build-cli.js",
    "build:web": "npm run ensure:unicode-data && node scripts/build-web.js",
    "lint": "semistandard .",
    "test": "npm run ensure:unicode-data && node --test",
    "start": "npm run ensure:unicode-data && npm run build:icon && electron-forge start",
    "package": "npm run ensure:unicode-data && npm run build:icon && electron-forge package",
    "make": "npm run ensure:unicode-data && npm run build:icon && electron-forge make"
  },
  "author": "David Cantrell",
  "repository": {
    "type": "git",
    "url": "https://github.com/DrHyde/unicode-search.git"
  },
  "license": "GPL-2.0-only",
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.6.0",
    "@electron-forge/plugin-fuses": "^7.6.0",
    "@electron/fuses": "^1.8.0",
    "electron": "^33.2.1",
    "semistandard": "^17.0.0"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "playwright": "^1.59.1"
  }
}
